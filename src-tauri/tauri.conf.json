{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Strata",
  "version": "0.1.0",
  "identifier": "net.ducatillon.strata",
  "build": {
    "frontendDist": "../front/dist/client",
    "devUrl": "http://localhost:4321",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Strata",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "resources": [
      "../backend/dist/**",
      "../backend/node_modules/**",
      "../backend/prisma/**",
      "../backend/package.json"
    ]
  }
}
