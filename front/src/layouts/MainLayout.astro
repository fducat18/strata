---
import '../styles/globals.css';
import { AppShell } from '../components/layout/AppShell';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Strata</title>
    <!--
      CSS-only dark-mode background: applied immediately on HTML parse, before
      any stylesheet or JavaScript runs. Prevents a white flash between page
      navigations for users in dark mode.

      • The media query covers users whose system preference is dark.
      • The html.dark rule covers users who explicitly chose dark in settings
        (the is:inline script below adds/removes that class synchronously).
    -->
    <style is:inline>
      @media (prefers-color-scheme: dark) {
        html:not([data-theme='light']) {
          background-color: #0f172a;
          color: #f8fafc;
        }
      }
      html.dark {
        background-color: #0f172a;
        color: #f8fafc;
      }
    </style>
    <!--
      Synchronous theme pre-load: reads localStorage and sets `dark` on <html>
      BEFORE any paint. Must use is:inline so Astro does not convert it to a
      deferred <script type="module">, which would cause a flash of unstyled
      content (FOUC) on every navigation in dark mode.
    -->
    <script is:inline>
      (function () {
        try {
          var root = document.documentElement;
          var t = localStorage.getItem('strata.theme') || 'system';
          var dark =
            t === 'dark' ||
            (t === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          root.classList.toggle('dark', dark);
          root.dataset.theme = t;
          root.style.colorScheme = dark ? 'dark' : 'light';
          // Avoid white flash before CSS loads on route navigation.
          root.style.backgroundColor = dark ? '#0f172a' : '#ffffff';
          root.style.color = dark ? '#f8fafc' : '#0f172a';
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <!--
      We use client:load for the full AppShell because Strata is an interactive
      financial dashboard — every page requires React state (queries, mutations,
      modals, charts). Astro acts as the router / SSR shell only; static-first
      rendering provides no UX benefit here. Individual page components inside
      <slot /> also use client:load for the same reason.

      Header, sidebar, and theme toggle live inside AppShell and share its
      hydration boundary, so splitting them into client:idle or client:visible
      would add complexity with no measurable gain.
    -->
    <AppShell currentPath={currentPath} client:load>
      <slot />
    </AppShell>
    <script>
      import { initTheme } from '../lib/theme';
      initTheme();
    </script>
  </body>
</html>
