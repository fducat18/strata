generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Asset {
  id          String               @id @default(uuid())
  name        String
  quantity    Decimal?
  disposed    Boolean              @default(false)
  assetTypeId String               @map("asset_type_id")
  assetType   AssetType            @relation(fields: [assetTypeId], references: [id])
  snapshots   AssetSnapshot[]
  transactions Transaction[]
  categories  CategoriesOnAssets[]
  tags        TagsOnAssets[]
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@map("assets")
}

enum AssetTypeGroup {
  FINANCIAL
  REAL_ESTATE
  PERSONAL_PROPERTY
  PHYSICAL_COLLECTIONS
  LIABILITIES
  OTHER
}

model AssetType {
  id     String         @id @default(uuid())
  code   String         @unique
  label  String
  group  AssetTypeGroup
  assets Asset[]

  @@map("asset_types")
}

model Category {
  id       String               @id @default(uuid())
  name     String               @unique
  parentId String?              @map("parent_id")
  parent   Category?            @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[]           @relation("CategoryHierarchy")
  assets   CategoriesOnAssets[]

  @@index([parentId])
  @@map("categories")
}

model Tag {
  id     String         @id @default(uuid())
  name   String         @unique
  assets TagsOnAssets[]

  @@map("tags")
}

model AssetSnapshot {
  id         String   @id @default(uuid())
  assetId    String   @map("asset_id")
  value      Decimal
  observedAt DateTime @map("observed_at")
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([assetId, observedAt(sort: Desc)])
  @@map("asset_snapshots")
}

// Standalone snapshot of total portfolio value at a point in time.
// "Portfolio" in Strata = everything you own — not linked to a Portfolio table (which no longer exists).
model PortfolioSnapshot {
  id         String   @id @default(uuid())
  value      Decimal
  currency   String   @default("EUR")
  notes      String?
  observedAt DateTime @unique @map("observed_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([observedAt(sort: Desc)])
  @@map("portfolio_snapshots")
}

enum TransactionType {
  ACQUIRE
  DISPOSE
  ADJUST
}

model Transaction {
  id         String          @id @default(uuid())
  assetId    String          @map("asset_id")
  type       TransactionType
  unitPrice  Decimal         @map("unit_price")
  quantity   Decimal
  currency   String
  occurredAt DateTime        @map("occurred_at")
  asset      Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([assetId, occurredAt(sort: Desc)])
  @@map("transactions")
}

model CategoriesOnAssets {
  assetId    String   @map("asset_id")
  categoryId String   @map("category_id")
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([assetId, categoryId])
  @@index([categoryId])
  @@map("asset_categories")
}

model TagsOnAssets {
  assetId String @map("asset_id")
  tagId   String @map("tag_id")
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([assetId, tagId])
  @@index([tagId])
  @@map("asset_tags")
}
