# Example environment variables for Strata backend
# Default environment
ENV=development

# DATABASE_URL examples — choose ONE and copy to `backend/.env`
#
# SQLite (no extra services)
# - Container (recommended when running via Docker Compose):
#   DATABASE_URL=sqlite:////app/.data/strata.db
# - Host (when running on the host with Poetry):
#   DATABASE_URL=sqlite://$(pwd)/.data/strata.db
#
# Postgres (requires the postgres service)
# - Docker Compose internal (service-to-service, containers talk on port 5432):
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/strata
# - Host access (when Postgres is exposed on the host; `docker-compose.yml` maps
#   container port 5432 → host port 5434):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5434/strata
#
# Summary: use `postgres:5432` inside compose network; use `localhost:5434` from host.

# Postgres connection defaults (used by the postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=strata
